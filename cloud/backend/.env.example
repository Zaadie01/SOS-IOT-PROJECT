# Server
PORT=3001

# JWT — keep this long and secret
JWT_SECRET=change-me-to-a-long-random-string

# Session — used only during Google OAuth redirect dance
SESSION_SECRET=change-me-too

# Admin user (seeded on first start)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Legacy gateway registration (optional — use per-device codes instead)
REGISTRATION_SECRET=

# Google OAuth (optional — leave blank to disable Google login)
# 1. Go to https://console.cloud.google.com/
# 2. Create a project → APIs & Services → Credentials → OAuth 2.0 Client ID
# 3. Add authorised redirect URI: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Frontend URL (used for Google OAuth redirect after login)
FRONTEND_URL=http://localhost:3000
