# Serial port of the HARDWARIO device
# Linux: /dev/ttyUSB0 or /dev/ttyACM0
# macOS: /dev/cu.usbserial-*
SERIAL_PORT=/dev/ttyUSB0

# URL of the cloud backend (no trailing slash)
CLOUD_URL=https://app-project.org

# Registration code from the SOS IoT dashboard
# 1. Go to app-project.org → Devices → Add Device
# 2. Enter a name for this device
# 3. Copy the 8-character registration code shown and paste it below
# The code is one-time and expires in 24 hours.
# After first successful registration the token is saved locally — this value is no longer needed.
REGISTRATION_CODE=

# Optional overrides (defaults shown)
# DASHBOARD_PORT=8080
# UPLOAD_INTERVAL_MS=30000
# SENT_RETENTION_MS=86400000
# REGISTER_RETRY_MS=10000
# HEARTBEAT_INTERVAL_MS=60000
# DB_PATH=/data/gateway.db
